
<!DOCTYPE html>
<html lang="en" data-theme="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HabitRiver - Gamified Habit Tracker</title>
    <link rel="stylesheet" href="index.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body>
    <div class="container">
        <header>
            <div class="brand">
                <h1>🌊 HabitRiver</h1>
                <p>Flow Your Progress, Level Up Your Life</p>
            </div>
            <div class="header-right">
                <button id="theme-toggle" class="btn-icon">☀️ Light Mode</button>
            </div>
        </header>

        <section class="profile-section">
            <div class="profile-info">
                <div class="avatar">👑</div>
                <div>
                    <h2 id="user-level">Level 1 (Novice)</h2>
                    <div class="xp-bar-container">
                        <div id="xp-bar" class="xp-bar-fill" style="width: 0%"></div>
                    </div>
                    <span id="xp-text">0 / 100 XP</span>
                </div>
            </div>
        </section>

        <div class="main-layout">
            <div class="left-column">
                <section class="card">
                    <h2>Add New Habit</h2>
                    <form id="habit-form">
                        <input type="text" id="habit-name" placeholder="E.g., Coding, Read Book..." required>
                        <select id="habit-category">
                            <option value="💻 Coding">💻 Coding</option>
                            <option value="🏃 Health">🏃 Health</option>
                            <option value="📚 Study">📚 Study</option>
                            <option value="💰 Finance">💰 Finance</option>
                        </select>
                        <button type="submit" class="btn-primary">Add</button>
                    </form>
                </section>

                <section class="card">
                    <h2>Your Habits</h2>
                    <div class="filter-container">
                        <button class="btn-filter active" onclick="filterHabits('All')">All</button>
                        <button class="btn-filter" onclick="filterHabits('💻 Coding')">💻 Coding</button>
                        <button class="btn-filter" onclick="filterHabits('🏃 Health')">🏃 Health</button>
                        <button class="btn-filter" onclick="filterHabits('📚 Study')">📚 Study</button>
                        <button class="btn-filter" onclick="filterHabits('💰 Finance')">💰 Finance</button>
                    </div>
                    <div id="habit-list"></div>
                </section>
            </div>

            <div class="right-column">
                <section class="card">
                    <h2>📊 Weekly Progress</h2>
                    <div class="chart-container">
                        <canvas id="progressChart"></canvas>
                    </div>
                </section>

                <section class="card">
                    <h2>🏆 Top Chart (Leaderboard)</h2>
                    <div id="leaderboard-list"></div>
                </section>
            </div>
        </div>
    </div>

    <script src="index.js"></script>
</body>

</html>

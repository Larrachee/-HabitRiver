// --- STATE ---
let habits = JSON.parse(localStorage.getItem('habits')) || [];
let userProfile = JSON.parse(localStorage.getItem('userProfile')) || { xp: 0, level: 1 };
let currentFilter = 'All';
let progressChart;

// --- COMPETITORS ---
const competitors = [
    { name: "⚡ HabitMaster", baseXp: 450, level: 4 },
    { name: "🔥 CodeSamurai", baseXp: 280, level: 3 },
    { name: "🏃 KeepRunning", baseXp: 120, level: 2 },
    { name: "📚 BookWorm", baseXp: 50, level: 1 },
    { name: "🎨 CreativeMind", baseXp: 180, level: 2 },
    { name: "🧘 ZenMaster", baseXp: 90, level: 1 }
];

// --- DOM Elements ---
const habitForm = document.getElementById('habit-form');
const habitNameInput = document.getElementById('habit-name');
const habitCategoryInput = document.getElementById('habit-category');
const habitList = document.getElementById('habit-list');
const themeToggle = document.getElementById('theme-toggle');
const toastContainer = document.getElementById('toast-container');
const resetDataBtn = document.getElementById('reset-data');

// --- THEME ---
const savedTheme = localStorage.getItem('theme') || 'dark';
document.documentElement.setAttribute('data-theme', savedTheme);
updateThemeButton(savedTheme);

themeToggle.addEventListener('click', () => {
    const currentTheme = document.documentElement.getAttribute('data-theme');
    const newTheme = currentTheme === 'light' ? 'dark' : 'light';
    document.documentElement.setAttribute('data-theme', newTheme);
    localStorage.setItem('theme', newTheme);
    updateThemeButton(newTheme);
});

function updateThemeButton(theme) {
    const icon = theme === 'light' ? 'fa-sun' : 'fa-moon';
    const text = theme === 'light' ? 'Light Mode' : 'Dark Mode';
    themeToggle.innerHTML = `<i class="fas ${icon}"></i> ${text}`;
}

// --- RESET DATA ---
resetDataBtn.addEventListener('click', () => {
    if (confirm('Are you sure you want to reset all data? This cannot be undone!')) {
        localStorage.clear();
        habits = [];
        userProfile = { xp: 0, level: 1 };
        localStorage.setItem('userProfile', JSON.stringify(userProfile));
        showToast('All data has been reset', 'error');
        saveAndRender();
    }
});

// --- TOAST SYSTEM ---
function showToast(message, type = 'success', duration = 3000) {
    const toast = document.createElement('div');
    toast.className = `toast ${type}`;
    const icons = {
        success: 'fa-check-circle',
        error: 'fa-exclamation-circle',
        'level-up': 'fa-star'
    };
    toast.innerHTML = `
        <i class="fas ${icons[type] || icons.success}" style="color: var(--primary-color);"></i>
        <span>${message}</span>
        <button class="toast-close" onclick="this.parentElement.remove()">&times;</button>
    `;
    toastContainer.appendChild(toast);
    setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transform = 'translateX(100%)';
        setTimeout(() => toast.remove(), 300);
    }, duration);
}

// --- DATE UTILS ---
function getPastSevenDays() {
    const days = [];
    for (let i = 6; i >= 0; i--) {
        const d = new Date();
        d.setDate(d.getDate() - i);
        const dateStr = d.toISOString().split('T')[0];
        const label = d.toLocaleDateString('en-US', { weekday: 'short' });
        days.push({ dateStr, label });
    }
    return days;
}

function getTodayStr() {
    return new Date().toISOString().split('T')[0];
}

// --- STREAK CALCULATION ---
function calculateStreak(history) {
    let streak = 0;
    let checkDate = new Date();
    let todayStr = getTodayStr();
    
    if (!history[todayStr]) {
        checkDate.setDate(checkDate.getDate() - 1);
    }
    
    while (true) {
        let dateStr = checkDate.toISOString().split('T')[0];
        if (history[dateStr]) {
            streak++;
            checkDate.setDate(checkDate.getDate() - 1);
        } else {
            break;
        }
    }
    return streak;
}

function getBestStreak(history) {
    let dates = Object.keys(history).sort();
    if (dates.length === 0) return 0;
    
    let bestStreak = 1;
    let currentStreak = 1;
    
    for (let i = 1; i < dates.length; i++) {
        const prev = new Date(dates[i-1]);
        const curr = new Date(dates[i]);
        const diffDays = (curr - prev) / (1000 * 60 * 60 * 24);
        
        if (diffDays === 1) {
            currentStreak++;
            bestStreak = Math.max(bestStreak, currentStreak);
        } else if (diffDays > 1) {
            currentStreak = 1;
        }
    }
    return bestStreak;
}

// --- XP SYSTEM ---
function addXP(amount) {
    userProfile.xp += amount;
    let nextLevelXp = userProfile.level * 100;

    if (userProfile.xp >= nextLevelXp) {
        userProfile.xp -= nextLevelXp;
        userProfile.level += 1;
        showToast(`🎉 LEVEL UP! You reached Level ${userProfile.level}!`, 'level-up', 4000);
    } else if (userProfile.xp < 0) {
        if (userProfile.level > 1) {
            userProfile.level -= 1;
            userProfile.xp = (userProfile.level * 100) + userProfile.xp;
        } else {
            userProfile.xp = 0;
        }
    }
    localStorage.setItem('userProfile', JSON.stringify(userProfile));
    updateProfileUI();
    renderLeaderboard();
    updateStats();
}

// --- UPDATE UI ---
function updateProfileUI() {
    const nextLevelXp = userProfile.level * 100;
    const pct = Math.min((userProfile.xp / nextLevelXp) * 100, 100);
    const levelNames = ['Novice', 'Explorer', 'Champion', 'Master', 'Legend', 'Mythic'];
    const levelName = levelNames[Math.min(userProfile.level - 1, levelNames.length - 1)] || 'Legend';
    
    document.getElementById('user-level').textContent = `Level ${userProfile.level} (${levelName})`;
    document.getElementById('xp-bar').style.width = `${pct}%`;
    document.getElementById('xp-text').textContent = `${Math.floor(userProfile.xp)} / ${nextLevelXp} XP`;
    
    let totalXp = userProfile.xp;
    for (let i = 1; i < userProfile.level; i++) {
        totalXp += i * 100;
    }
    document.getElementById('total-xp').textContent = totalXp;
}

function updateStats() {
    const today = getTodayStr();
    const total = habits.length;
    const completedToday = habits.filter(h => h.history[today]).length;
    const bestStreak = habits.reduce((max, h) => Math.max(max, getBestStreak(h.history)), 0);
    
    document.getElementById('total-habits').textContent = total;
    document.getElementById('completed-today').textContent = completedToday;
    document.getElementById('streak-count').textContent = bestStreak;
}

// --- LEADERBOARD ---
function renderLeaderboard() {
    const leaderboardList = document.getElementById('leaderboard-list');
    leaderboardList.innerHTML = '';
    
    let totalUserXp = userProfile.xp;
    for (let i = 1; i < userProfile.level; i++) {
        totalUserXp += i * 100;
    }

    let boardData = [
        { name: "👑 You", totalXp: totalUserXp, level: userProfile.level, isUser: true },
        ...competitors.map(c => ({ 
            name: c.name, 
            totalXp: c.baseXp + (c.level - 1) * 100, 
            level: c.level, 
            isUser: false 
        }))
    ];
    boardData.sort((a, b) => b.totalXp - a.totalXp);

    boardData.forEach((player, index) => {
        const row = document.createElement('div');
        row.classList.add('leaderboard-item');
        if (player.isUser) row.classList.add('user-row');
        
        let rankClass = '';
        if (index === 0) rankClass = 'gold';
        else if (index === 1) rankClass = 'silver';
        else if (index === 2) rankClass = 'bronze';
        
        row.innerHTML = `
            <span class="rank ${rankClass}">#${index + 1}</span>
            <span class="player-name">${player.name}</span>
            <span class="player-score">Lv.${player.level} (${player.totalXp} XP)</span>
        `;
        leaderboardList.appendChild(row);
    });
}

// --- CHART ---
function updateChart() {
    const pastDays = getPastSevenDays();
    const labels = pastDays.map(d => d.label);
    const dataValues = pastDays.map(day => 
        habits.filter(h => h.history[day.dateStr]).length
    );

    if (progressChart) { progressChart.destroy(); }

    const ctx = document.getElementById('progressChart').getContext('2d');
    const gradient = ctx.createLinearGradient(0, 0, 0, 250);
    gradient.addColorStop(0, 'rgba(56, 189, 248, 0.2)');
    gradient.addColorStop(1, 'rgba(56, 189, 248, 0)');

    progressChart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
                label: 'Habits Completed',
                data: dataValues,
                borderColor: '#38bdf8',
                backgroundColor: gradient,
                borderWidth: 3,
                tension: 0.4,
                fill: true,
                pointBackgroundColor: '#38bdf8',
                pointBorderColor: 'var(--bg-color)',
                pointBorderWidth: 2,
                pointRadius: 5,
                pointHoverRadius: 8
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    display: false
                }
            },
            scales: {
                y: { 
                    beginAtZero: true, 
                    ticks: { 
                        stepSize: 1,
                        color: 'var(--text-muted)'
                    },
                    grid: {
                        color: 'var(--border-color)'
                    }
                },
                x: {
                    grid: {
                        display: false
                    },
                    ticks: {
                        color: 'var(--text-muted)'
                    }
                }
            },
            interaction: {
                intersect: false,
                mode: 'index'
            }
        }
    });
}

// --- FILTER ---
function filterHabits(category) {
    currentFilter = category;
    const filterButtons = document.querySelectorAll('.btn-filter');
    filterButtons.forEach(btn => {
        if (btn.dataset.filter === category) {
            btn.classList.add('active');
        } else {
            btn.classList.remove('active');
        }
    });
    renderHabits();
}

// Setup filter buttons
document.querySelectorAll('.btn-filter').forEach(btn => {
    btn.addEventListener('click', () => {
        filterHabits(btn.dataset.filter);
    });
});

// --- CRUD OPERATIONS ---
habitForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const name = habitNameInput.value.trim();
    const category = habitCategoryInput.value;
    if (!name) return;

    const newHabit = {
        id: Date.now().toString(),
        name: name,
        category: category,
        history: {}
    };

    habits.push(newHabit);
    saveAndRender();
    habitNameInput.value = '';
    showToast(`✅ Habit "${name}" added successfully!`, 'success');
});

// Toggle habit completion
window.toggleHabit = function(id, dateStr) {
    habits = habits.map(habit => {
        if (habit.id === id) {
            if (habit.history[dateStr]) {
                delete habit.history[dateStr];
                addXP(-15);
                showToast('↩️ Habit undone (-15 XP)', 'error');
            } else {
                habit.history[dateStr] = true;
                addXP(15);
                showToast('✅ Habit completed! (+15 XP)', 'success');
            }
        }
        return habit;
    });
    saveAndRender();
};

// Delete habit
window.deleteHabit = function(id) {
    if (confirm('Delete this habit?')) {
        const habit = habits.find(h => h.id === id);
        habits = habits.filter(habit => habit.id !== id);
        saveAndRender();
        if (habit) {
            showToast(`🗑️ "${habit.name}" deleted`, 'error');
        }
    }
};

function saveAndRender() {
    localStorage.setItem('habits', JSON.stringify(habits));
    renderHabits();
    updateChart();
    renderLeaderboard();
    updateStats();
    updateProfileUI();
}

// --- RENDER HABITS ---
function renderHabits() {
    habitList.innerHTML = '';
    const pastDays = getPastSevenDays();
    const todayStr = getTodayStr();

    const filteredHabits = habits.filter(habit => {
        if (currentFilter === 'All') return true;
        return habit.category === currentFilter;
    });

    if (filteredHabits.length === 0) {
        habitList.innerHTML = `
            <div class="empty-state">
                <i class="fas fa-inbox"></i>
                <p>No habits found in this category.</p>
                <p style="font-size: 0.85rem; margin-top: 4px;">Start building your habits today!</p>
            </div>
        `;
        return;
    }

    filteredHabits.forEach(habit => {
        const habitCard = document.createElement('div');
        habitCard.classList.add('habit-card');

        const isDoneToday = habit.history[todayStr] ? true : false;
        const streak = calculateStreak(habit.history);

        habitCard.innerHTML = `
            <div class="habit-header">
                <div class="habit-title-area">
                    <h3>${habit.name}</h3>
                    <span class="category-tag">${habit.category || '📦 General'}</span>
                    <span class="streak-badge">🔥 ${streak} Days</span>
                </div>
                <div class="habit-actions">
                    <button class="btn-done ${isDoneToday ? 'undo' : ''}" onclick="toggleHabit('${habit.id}', '${todayStr}')">
                        <i class="fas ${isDoneToday ? 'fa-undo' : 'fa-check'}"></i>
                        ${isDoneToday ? 'Undo' : 'Done (+15 XP)'}
                    </button>
                    <button class="btn-delete" onclick="deleteHabit('${habit.id}')">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>
            </div>
            <div class="grid-container" id="grid-${habit.id}"></div>
        `;

        habitList.appendChild(habitCard);

        const gridContainer = document.getElementById(`grid-${habit.id}`);
        pastDays.forEach(day => {
            const dayWrapper = document.createElement('div');
            dayWrapper.classList.add('grid-day');

            const cube = document.createElement('div');
            cube.classList.add('cube');
            if (habit.history[day.dateStr]) cube.classList.add('completed');

            const label = document.createElement('span');
            label.textContent = day.label;

            dayWrapper.appendChild(cube);
            dayWrapper.appendChild(label);
            gridContainer.appendChild(dayWrapper);
        });
    });
}

// --- INITIALIZATION ---
function init() {
    updateProfileUI();
    renderHabits();
    updateChart();
    renderLeaderboard();
    updateStats();
}

// Run initialization
init();
